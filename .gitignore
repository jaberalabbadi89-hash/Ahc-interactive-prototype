# ==========================================
# 1. ملفات نظام التشغيل (macOS)
# ==========================================
# تجاهل ملفات النظام المخفية التي ينشئها macOS تلقائياً
.DS_Store
Thumbs.db

# ==========================================
# 2. ملفات البيئة والإعدادات الحساسة
# ==========================================
# تجاهل ملفات البيئة التي تحتوي على مفاتيح API أو كلمات مرور
.env
.env.local
.env.production
.env.development
# نترك .env.example ليقوم المطورون بملء القيم المطلوبة

# ==========================================
# 3. إعدادات المحررات (IDE)
# ==========================================
# تجاهل إعدادات المجلدات المحلية للمحررات
.vscode/
.idea/

# ==========================================
# 4. السجلات والملفات المؤقتة
# ==========================================
# تجاهل سجلات الأخطاء والملفات المؤقتة للمتصفح أو الأدوات
*.log
npm-debug.log*
yarn-debug.log*
.cache/
tmp/
temp/
AHC_Interactive_Prototype.zip

# ==========================================
# 5. مجلدات البناء (اختياري - في حال استخدام أدوات بناء)
# ==========================================
# تجاهل مجلدات المخرجات النهائية (إذا قمت باستخدام أدوات مستقبلاً)
dist/
build/
coverage/

# ==========================================
# 6. اختياري (لأدوات مستقبلية مثل Node.js أو Vite)
# ==========================================
# هذه القواعد مضافة للاستعداد مستقبلاً
node_modules/
package-lock.json
